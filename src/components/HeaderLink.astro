---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const isActive = href === pathname || (href !== '/' && pathname.startsWith(String(href)));
---

<a href={href} class:list={['nav-link', className, { active: isActive }]} {...props}>
  <slot />
</a>

<style>
  .nav-link {
    font-family: var(--font-ui, 'DM Sans', sans-serif);
    font-size: 0.83rem;
    font-weight: 400;
    color: rgb(var(--ink-mid, 55, 52, 46));
    text-decoration: none;
    padding: 0.35rem 0.65rem;
    border-radius: 4px;
    letter-spacing: 0.01em;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: rgba(15, 14, 11, 0.06);
    color: rgb(var(--ink, 15, 14, 11));
  }

  .nav-link.active {
    background: var(--accent-soft, #e8eef5);
    color: var(--accent, #1a3a5c);
    font-weight: 500;
  }
</style>
